# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Gemini API key
GEMINI_API_KEY=

# Flask settings
FLASK_ENV=
PORT=
SECRET_KEY=

# GitHub integration for MCP
GITHUB_TOKEN=

# Netlify integration for MCP
NETLIFY_API_KEY=

# MCP (Model Context Protocol) configuration
MCP_CONFIG_PATH=
# Seconds to wait for npx MCP servers + tool list (WSL + /mnt/c/ can be slow; try 600 if needed)
MCP_START_TIMEOUT=300

# Redis: sessions + Twilio idempotency; required for RQ background jobs
REDIS_URL=redis://localhost:6379/0
# On native Windows, RQ is auto-disabled (RQ requires Unix fork); jobs use threads instead.
# Set to 0 to force threads on Linux too. Run python run_worker.py only on Linux/macOS/WSL.
USE_RQ=1
RQ_QUEUE_NAME=waweb
RQ_JOB_TIMEOUT=600
TWILIO_IDEMPOTENCY_TTL_SECONDS=86400
REDIS_SESSION_PREFIX=waweb:session:
REDIS_IDEMPOTENCY_PREFIX=waweb:msg:

# Gunicorn (production web — Linux/macOS only; not supported on Windows)
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
BIND=0.0.0.0:5000

# Waitress (production-style web on Windows): python serve_waitress.py
WAITRESS_THREADS=8
BIND_HOST=0.0.0.0